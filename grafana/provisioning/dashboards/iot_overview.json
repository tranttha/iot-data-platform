      "type": "table",
      "targets": [
        {
          "datasource": {
            "type": "trino-datasource",
            "uid": "trino_lakehouse"
          },
          "format": 1,
          "rawQuery": true,
          "rawSQL": "SELECT iot_device_id,\n       country_code,\n       ROUND(AVG(temp), 2)       AS avg_temp,\n       ROUND(AVG(humidity), 2)   AS avg_humidity,\n       ROUND(AVG(wind_speed), 2) AS avg_wind_speed,\n       COUNT(*)                  AS record_count\nFROM lakehouse.warehouse.fact_measurements\nWHERE event_time >= now() - INTERVAL '1' HOUR\nGROUP BY iot_device_id, country_code\nORDER BY iot_device_id"
        }
